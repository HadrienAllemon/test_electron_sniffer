{
  "name": "test_electron_sniffer",
  "productName": "test_electron_sniffer",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "get-categories": "cross-env ELECTRON_RUN_AS_NODE=1 .\\node_modules\\.bin\\electron -r ts-node/register scripts/itemType.ts",
    "import-pet-xp": "cross-env ELECTRON_RUN_AS_NODE=1 .\\node_modules\\.bin\\electron -r ts-node/register scripts/importPetItemXp.ts",
    "get-pet-xp": "cross-env ELECTRON_RUN_AS_NODE=1 .\\node_modules\\.bin\\electron -r ts-node/register scripts/getPetItemXp.ts",
    "postinstall": "electron-rebuild",
    "test": "jest"
  },
  "build": {
    "extraResources": [
      "./node_modules/@electron/remote/**"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.0",
    "@electron-forge/plugin-fuses": "^7.6.0",
    "@electron-forge/plugin-webpack": "^7.6.0",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "cross-env": "^10.1.0",
    "css-loader": "^6.11.0",
    "electron": "32.2.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "jest": "^29.7.0",
    "module-alias": "^2.2.3",
    "node-loader": "^2.1.0",
    "style-loader": "^3.3.4",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "~4.5.4"
  },
  "keywords": [],
  "author": {
    "name": "Hadrien Allemon",
    "email": "hadrienallemon@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@chakra-ui/react": "^2.10.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@jitsi/robotjs": "^0.6.21",
    "ag-grid-react": "^33.0.4",
    "better-sqlite3": "^11.8.1",
    "cap": "^0.2.1",
    "chalk": "^5.4.1",
    "chart.js": "^4.4.7",
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.0.1",
    "fuse.js": "^7.3.0",
    "jotai": "^2.11.3",
    "protobufjs": "^7.4.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0",
    "robotjs": "^0.7.0"
  }
}
